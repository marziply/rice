#!/usr/bin/env python3
import json
import psutil
import subprocess
import argparse
import time

def get_sway_tree_from_file(filename):
    with open(filename, "r") as f:
        return json.load(f)

def iter_windows(node):
    if node.get("type") == "con" and node.get("window_properties") and node.get("pid"):
        yield node
    for child in node.get("nodes", []):
        yield from iter_windows(child)
    for child in node.get("floating_nodes", []):
        yield from iter_windows(child)

def get_cmdline_from_pid(pid):
    try:
        with open(f"/proc/{pid}/cmdline", "r") as f:
            cmdline = f.read().split("\0")
            return [arg for arg in cmdline if arg]
    except Exception:
        return None

def is_process_running(pid):
    return psutil.pid_exists(pid)

def launch_window(cmd):
    print(f"Launching: {' '.join(cmd)}")
    subprocess.Popen(cmd)

def main():
    parser = argparse.ArgumentParser(description="Launch missing windows from sway tree JSON")
    parser.add_argument("--file", required=True, help="Sway tree JSON file")
    args = parser.parse_args()

    tree = get_sway_tree_from_file(args.file)

    for window in iter_windows(tree):
        pid = window.get("pid")
        cmdline = get_cmdline_from_pid(pid)
        if not cmdline:
            continue
        if not is_process_running(pid):
            launch_window(cmdline)

if __name__ == "__main__":
    main()
